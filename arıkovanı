// ═══════════════════════════════════════════
// CARGO CALCULATION ENGINE
// ═══════════════════════════════════════════
function lookupDesi(desi,tariff){
  if(!tariff||!tariff.length)return 100;
  const s=[...tariff].sort((a,b)=>a.d-b.d);
  if(desi<=s[0].d)return s[0].p;
  const last=s[s.length-1];
  if(desi>=last.d){
    if(s.length<2)return last.p;
    const prev=s[s.length-2];
    return last.p+(last.p-prev.p)/(last.d-prev.d)*(desi-last.d);
  }
  for(let i=1;i<s.length;i++){
    if(desi<=s[i].d){
      const lo=s[i-1],hi=s[i],t=(desi-lo.d)/(hi.d-lo.d);
      return lo.p+t*(hi.p-lo.p);
    }
  }
  return last.p;
}

function calcKargo(mp,salePrice,desi,order={}){
  const def=defSettings()[mp]||{};
  const c={...def, ...(S.settings[mp]||{})};
  if(mp==='trendyol'){
    const sinir = c.baremSinir||350;
    const desiSinir = c.baremDesiSinir||10;
    const barem = salePrice < sinir && desi <= desiSinir;
    if(barem){
      const av=c.baremType==='avantajli';
      const bAvAlt = c.baremAvAlt || def.baremAvAlt;
      const bAvUst = c.baremAvUst || def.baremAvUst;
      const bStAlt = c.baremStAlt || def.baremStAlt;
      const bStUst = c.baremStUst || def.baremStUst;
      const price=salePrice<=199?(av?TRY(bAvAlt):TRY(bStAlt)):(av?TRY(bAvUst):TRY(bStUst));
      return{price,type:'barem',label:`Barem ${av?'Avantajlı':'Standart'} (${salePrice<=199?'0-199':'200-349'} TL)`,rawKargo:price,contrib:0};
    }
    const firmStr=String(order.cargoFirm||c.defaultCargoFirm||'TEX').toUpperCase();
    const isPTT = firmStr.includes('PTT');
    const tariff=isPTT?(c.desiTariffPTT||def.desiTariffPTT):(c.desiTariffTEX||def.desiTariffTEX);
    const price=lookupDesi(desi,tariff);
    let reason = '';
    if (salePrice >= sinir) reason = ` (Tutar ${sinir} TL üzeri!)`;
    else if (desi > desiSinir) reason = ` (Desi > ${desiSinir}!)`;
    return{price,type:'desi',label:`Desi bazlı ${isPTT?'PTT':'TEX'} (${desi} desi)${reason}`,rawKargo:price,contrib:0};
  }
  if(mp==='hepsiburada'){
    const barem=salePrice<(c.baremSinir||400)&&c.deliveryFast;
    if(barem){
      const bAlt = c.baremAlt || def.baremAlt;
      const bUst = c.baremUst || def.baremUst;
      const price=salePrice<=199?TRY(bAlt):TRY(bUst);
      return{price,type:'barem',label:`hepsiJET Barem (${salePrice<=199?'0-199':'200-399'} TL)`,rawKargo:price,contrib:0};
    }
    const firmStr=String(order.cargoFirm||c.defaultCargoFirm||'HJ').toUpperCase();
    const isPTT = firmStr.includes('PTT');
    const tariff=isPTT?(c.desiTariffPTT||def.desiTariffPTT):(c.desiTariffHJ||def.desiTariffHJ);
    const price=lookupDesi(desi,tariff);
    return{price,type:'desi',label:`Desi bazlı ${isPTT?'PTT Kargo':'hepsiJET'} (${desi} desi)`,rawKargo:price,contrib:0};
  }
  // temu
  const tariff = c.desiTariff || def.desiTariff;
  const rawKargo=lookupDesi(desi,tariff);
  const contrib=salePrice<(c.baremSinir||350)?TRY(c.customerContrib||def.customerContrib):0;
  const price=Math.max(0,rawKargo-contrib);
  return{price,type:contrib>0?'barem':'desi',label:contrib>0?`Aras (${rawKargo.toFixed(2)} − ${contrib} müşteri katkısı)`:`Aras Desi (${desi} desi)`,rawKargo,contrib};
}

// ═══════════════════════════════════════════
// ORDER DETAILS CALCULATOR
// ═══════════════════════════════════════════
function getDynamicMultiplier(orderName, prod) {
  if (!orderName) return 1;
  const o = ' ' + String(orderName).toLowerCase() + ' ';
  
  // 1. Kesin Set/Paket/Koli Yakalama (Örn: "4 paket", "3 koli", "5 set")
  const pkgMatch = o.match(/(?:^|[^0-9])(\d+)\s*(?:paket|koli|set)(?:[^a-zçğıöşü]|$)/);
  if (pkgMatch) {
    const val = parseInt(pkgMatch[1]);
    if (val > 1 && val <= 50) return val;
  }
  
  // 2. Kampanya Yakalama (Örn: "3 al 2 öde" -> gönderilecek miktar 3'tür)
  const campMatch = o.match(/(?:^|[^0-9])(\d+)\s*al\s*\d+\s*(?:öde|bedava)/);
  if (campMatch) {
    const val = parseInt(campMatch[1]);
    if (val > 1 && val <= 50) return val;
  }
  
  // 3. AxB Çarpan Yakalama (Örn: "15x3", "3x20")
  const axbMatch = o.match(/(?:^|[^a-zçğıöşü0-9])(\d+)\s*x\s*(\d+)(?:[^a-zçğıöşü0-9]|$)/);
  if (axbMatch) {
    const v1 = parseInt(axbMatch[1]);
    const v2 = parseInt(axbMatch[2]);
    const bundle = Math.min(v1, v2); // Genellikle küçük olan sayı paket adedidir (Örn 15x3 -> 3 paket)
    if (bundle > 1 && bundle <= 50) return bundle;
  }

  // 4. Tekil Çarpan Yakalama (Örn: "x4", "4x")
  const xMatch = o.match(/(?:^|[^a-zçğıöşü0-9])(?:x\s*(\d+)|(\d+)\s*x)(?:[^a-zçğıöşü0-9]|$)/);
  if (xMatch) {
    const val = parseInt(xMatch[1] || xMatch[2]);
    if (val > 1 && val <= 50) return val;
  }
  const p = prod ? ' ' + String(prod.name).toLowerCase() + ' ' : '';
  let packSize = prod?.packSize || 0;
  
  // 5. "X'li" veya "X Adet" formatı
  // Burada ürünün ismindeki "X'li" ile karışmaması için kontrol yapıyoruz
  const liMatches = [...o.matchAll(/(?:^|[^0-9])(\d+)\s*(?:'?[l][ıiuü]|adet)(?:[^a-zçğıöşü]|$)/g)].map(m => parseInt(m[1]));
  
  // Eğer siparişteki rakam, ürünün kendi adında geçiyorsa iptal et (Örn: "4 numara", "4'lü" ile karışmasın diye. Ama 4'lü yazıyorsa p'de 4'lü var mı diye bakarız)
  const pLiMatches = [...p.matchAll(/(?:^|[^0-9])(\d+)\s*(?:'?[l][ıiuü]|adet)(?:[^a-zçğıöşü]|$)/g)].map(m => parseInt(m[1]));
  
  // EĞER KULLANICI ÜRÜNE PACKSIZE GİRMEDİYSE BİZ OTOMATİK BULALIM (Örn: 24'lü ürün için 24)
  if (!packSize && pLiMatches.length > 0) {
    packSize = Math.max(...pLiMatches);
  }

  // Sipariş isminden, ürün isminde zaten var olan sayıları çıkart
  let pureLi = liMatches.filter(val => !pLiMatches.includes(val));
  
  // Kalanlar arasında bölme mantığı (Örn: 120 adet, packSize=24 ise 5 paket)
  for (let val of pureLi) {
    if (packSize > 1 && val > packSize && val % packSize === 0) {
      const div = val / packSize;
      if (div > 1 && div <= 50) return div;
    }
  }
  
  // Bölme işlemi çalışmadıysa ve kalan sayılardan 2 ile 24 arasında olan varsa, bu bir 'X'li' bundle'dır.
  for (let val of pureLi) {
    if (val > 1 && val <= 24) return val;
  }
  
  // 5. Son çare: Sadece ham rakam okuma (Çok yüksek başarı oranı, 120 / 24)
  if (packSize > 1) {
    const rawNums = (o.match(/\d+/g) || []).map(Number);
    for (let r of rawNums) {
      if (r > packSize && r % packSize === 0) {
        const div = r / packSize;
        if (div > 1 && div <= 50) return div;
      }
    }
  }

  return 1;
}

function getProduct(name){
  if(!name) return null;
  const rawName = String(name).toLowerCase();
  const products = S.products || [];
  
  // 1. Manuel Eşleştirme (Alias) Kontrolü (%100 Doğruluk)
  for(let p of products){
    if(p.aliases && Array.isArray(p.aliases)){
      for(let a of p.aliases){
        if(rawName === String(a).toLowerCase() || rawName.includes(String(a).toLowerCase())){
          return p;
        }
      }
    } else if (p.aliases && typeof p.aliases === 'string') {
      // Geriye dönük uyumluluk (eski virgüllü sistem)
      const als = p.aliases.split(',').map(a=>a.trim().toLowerCase()).filter(a=>a);
      for(let a of als){
        if(rawName.includes(a)){
          return p;
        }
      }
    }
  }

  // 2. Otomatik (Fuzzy) Eşleştirme
  const stopWords = ['adet','paket','set','ve','ile','li','lı','lu','lü','için','boy'];
  const tokens=rawName.replace(/[^\wçğıöşü]/g,' ').split(/\s+/).filter(t=>t.trim().length>0 && !stopWords.includes(t));
  let bestMatch=null;
  let bestScore=0;
  
  for(let p of products){
    const pt=p.name.toLowerCase().replace(/[^\wçğıöşü]/g,' ').split(/\s+/).filter(t=>!stopWords.includes(t));
    let score=0;
    for(let t of tokens) if(pt.includes(t)) score++;
    
    if(score>0){
      const ratio = score / pt.length;
      if(score > bestScore || (score === bestScore && ratio > (bestMatch?._ratio||0))){
        bestScore = score;
        bestMatch = {...p, _ratio: ratio};
      }
    }
  }
  if(bestScore > 0){
    return bestMatch;
  }
  return null;
}

function calcOrderDetails(order,mp){
  const c=S.settings[mp]||{};
  const cfg=S.settings||{};
  const qty=parseInt(order.quantity||1)||1;
  const sp=TRY(order.salePrice);
  const totalRev=sp*qty;

  // Product
  const prod=getProduct(order.productName);
  const pcUnit=prod?TRY(prod.cost):0;
  const setMult=getDynamicMultiplier(order.productName, prod);
  const totalPhysicalQty = qty * setMult;
  
  const pcTotal=pcUnit * totalPhysicalQty;
  let desi;
  if (order.desi && parseFloat(order.desi) > 0) {
    desi = parseFloat(order.desi);
  } else {
    const desiBase=prod?.desi?TRY(prod.desi):(TRY(c.defaultDesi)||2);
    desi=desiBase * totalPhysicalQty; 
  }
  const kdvRateProd=prod?.kdvRate!==undefined?TRY(prod.kdvRate):(TRY(c.kdvRate)||20);

  let commission, kargo, kargoInfo;

  if(c.calcMode==='excel'){
    commission=TRY(order.commission);
    kargo=TRY(order.shippingCost);
    kargoInfo={price:kargo,type:'excel',label:'Excel verisi',rawKargo:kargo,contrib:0};
  } else {
    // Commission
    if(mp==='trendyol'){
      commission=totalRev*(TRY(c.commRate)||14)/100;
    } else if(mp==='hepsiburada'){
      const base=totalRev*(TRY(c.commRate)||13)/100;
      commission=base*(1+(TRY(c.commKdvRate)||20)/100);
    } else {
      commission=0;
    }
    // Barem limitleri birim fiyata değil, toplam sipariş tutarına göre hesaplanır.
    kargoInfo=calcKargo(mp,totalRev,desi,order);
    kargo=kargoInfo.price;
  }

  // Stopaj
  const stopaj=totalRev*(TRY(c.stopajRate)||1)/100;
  // Sabit hizmet (per order/row)
  const sabitHizmet=mp==='temu'?0:TRY(c.sabitHizmet);
  // Tahsilat (HB only)
  const tahsilat=mp==='hepsiburada'?totalRev*(TRY(c.tahsilatRate)||1)/100:0;

  // KDV (opsiyonel)
  let kdv=0;
  if(cfg.kdvEnabled){
    const kdvR=(TRY(c.kdvRate)||20)/100;
    const kdvSale=totalRev-totalRev/(1+kdvR);
    const kdvProd=pcTotal*(kdvRateProd/100); // indirebilir (maliyet KDV'siz varsayımı)
    const kdvKargo=kargo-kargo/1.20;
    kdv=Math.max(0,kdvSale-kdvProd-kdvKargo);
  }

  // Net tutar (marketplace pays seller)
  const netTutar=totalRev-commission-kargo;

  // Net profit
  let netProfit;
  if(mp==='trendyol'||mp==='hepsiburada'){
    netProfit=netTutar-pcTotal-stopaj-tahsilat-sabitHizmet-kdv;
  } else {
    // temu
    netProfit=totalRev-commission-kargo-pcTotal-stopaj-kdv;
  }
  const cpo=(commission+kargo+stopaj+sabitHizmet+tahsilat)/totalRev;
  const roas=totalRev/(commission+kargo+sabitHizmet);

  return{...order,qty,totalRev,pcUnit,setMult,totalPhysicalQty,pcTotal,desi,commission,kargo,kargoInfo,stopaj,sabitHizmet,tahsilat,kdv,netTutar,netProfit,cpo,roas,matchedProductName:prod?prod.name:null,matchedPackSize:prod?prod.packSize:null};
}

function calcOrderProfit(order,mp){return calcOrderDetails(order,mp).netProfit}

