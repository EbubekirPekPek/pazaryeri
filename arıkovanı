  const encrypted = localStorage.getItem('state_enc');
  if (!encrypted) {
    alert('Şifreli veri bulunamadı.');
    return;
  }
  const b=new Blob([encrypted],{type:'text/plain'});
  const u=URL.createObjectURL(b);
  const a=document.createElement('a');
  a.href=u;
  a.download=`pazaryeri_yedek_sifreli_${todayStr()}.txt`;
  a.click();
  URL.revokeObjectURL(u);
}
function importBackup(e){
  const f=e.target.files[0];
  if(!f)return;
  const r=new FileReader();
  r.onload=async ev=>{
    try {
      const fileContent = ev.target.result.trim();
      let importedState = null;
      try {
        const parsed = JSON.parse(fileContent);
        if (parsed && typeof parsed === 'object') {
          importedState = parsed;
        }
      } catch (jsonErr) {
        if (!activeSessionKey) {
          alert('Hata: Aktif oturum anahtarı bulunamadı.');
          return;
        }
        const decrypted = await decryptData(fileContent, activeSessionKey);
        if (decrypted) {
          importedState = JSON.parse(decrypted);
        } else {
          alert('Hata: Şifreli yedek bu şifreyle çözülemedi.');
          return;
        }
      }
      if (importedState) {
        if (!confirm('Mevcut veriler silinecek. Onaylıyor musunuz?')) return;
        S = importedState;
        await saveState();
        showToast('✅ Yedek başarıyla yüklendi');
        navigate('dashboard');
      } else {
        alert('Hata: Geçersiz yedek dosyası.');
      }
    } catch(err) {
      alert('Hata: ' + err.message);
    }
  };
  r.readAsText(f);
  e.target.value='';
}
function resetAll(){
  if(!confirm('⚠️ TÜM veriler silinecek!'))return;
  if(!confirm('Son onay — kalıcı olarak silinsin mi?'))return;
  localStorage.removeItem('state_enc');
  localStorage.removeItem('pwd_hash');
  localStorage.removeItem('pwd_salt');
  sessionStorage.removeItem('session_key');
  location.reload();
}

