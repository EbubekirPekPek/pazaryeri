// INTERACTIVE VISUAL EFFECTS (CONSTELLATION & SPOTLIGHT)
// ═══════════════════════════════════════════
function initSpotlight() {
  document.addEventListener('mousemove', e => {
    const card = e.target.closest('.sc, .cc, .tw, .ubox, .mphead');
    if (card) {
      const rect = card.getBoundingClientRect();
      const x = e.clientX - rect.left;
      const y = e.clientY - rect.top;
      card.style.setProperty('--mouse-x', `${x}px`);
      card.style.setProperty('--mouse-y', `${y}px`);
    }
  });
}

function initClickRipple() {
  document.addEventListener('click', e => {
    if (e.target.closest('input, select, textarea, option, button:not(.btn), select option')) return;
    const ripple = document.createElement('div');
    ripple.className = 'click-ripple';
    ripple.style.left = `${e.pageX}px`;
    ripple.style.top = `${e.pageY}px`;
    const brandCard = e.target.closest('.sc, .mphead, .ni');
    if (brandCard) {
      let color = '';
      if (brandCard.classList.contains('ty') || brandCard.classList.contains('ni-ty')) color = '249, 115, 22';
      else if (brandCard.classList.contains('hp') || brandCard.classList.contains('ni-hp')) color = '192, 132, 252';
      else if (brandCard.classList.contains('tm') || brandCard.classList.contains('temu') || brandCard.classList.contains('ni-temu')) color = '96, 165, 250';
      if (color) {
        ripple.style.background = `radial-gradient(circle, rgba(${color}, 0.5) 0%, rgba(${color}, 0) 70%)`;
        ripple.style.borderColor = `rgba(${color}, 0.6)`;
      }
    }
    document.body.appendChild(ripple);
    setTimeout(() => { ripple.remove(); }, 600);
  });
}

function initConstellation() {
  const canvas = document.getElementById('bg-canvas');
  if (!canvas) return;
  const ctx = canvas.getContext('2d');
  let particles = [];
  const mouse = { x: null, y: null, radius: 120 };
  
  window.addEventListener('mousemove', e => {
    mouse.x = e.clientX;
    mouse.y = e.clientY;
  });
  window.addEventListener('mouseout', () => {
    mouse.x = null;
    mouse.y = null;
  });
  
  function resize() {
    canvas.width = window.innerWidth;
    canvas.height = window.innerHeight;
    initParticles();
  }
  
  class Particle {
    constructor(x, y, vx, vy, size, color) {
      this.x = x;
      this.y = y;
      this.vx = vx;
      this.vy = vy;
      this.size = size;
      this.color = color;
      this.baseAlpha = 0.15 + Math.random() * 0.2;
      this.alpha = this.baseAlpha;
    }
    draw() {
      ctx.beginPath();
      ctx.arc(this.x, this.y, this.size, 0, Math.PI * 2);
      ctx.fillStyle = this.color.replace('ALPHA', this.alpha.toFixed(2));
      ctx.fill();
    }
    update() {
      if (this.x < 0 || this.x > canvas.width) this.vx = -this.vx;
      if (this.y < 0 || this.y > canvas.height) this.vy = -this.vy;
      this.x += this.vx;
      this.y += this.vy;
      if (mouse.x !== null && mouse.y !== null) {
        const dx = mouse.x - this.x;
        const dy = mouse.y - this.y;
        const dist = Math.sqrt(dx * dx + dy * dy);
        if (dist < mouse.radius) {
          const force = (mouse.radius - dist) / mouse.radius;
          this.x -= dx * force * 0.03;
          this.y -= dy * force * 0.03;
          this.alpha = Math.min(0.7, this.baseAlpha + force * 0.4);
        } else {
          if (this.alpha > this.baseAlpha) this.alpha -= 0.01;
        }
      } else {
        if (this.alpha > this.baseAlpha) this.alpha -= 0.01;
      }
      this.draw();
    }
  }
  
  function initParticles() {
    particles = [];
    const count = Math.min(75, Math.floor((canvas.width * canvas.height) / 22000));
    const colors = [
      'rgba(129, 140, 248, ALPHA)',
      'rgba(249, 115, 22, ALPHA)',
      'rgba(192, 132, 252, ALPHA)',
      'rgba(96, 165, 250, ALPHA)'
    ];
    for (let i = 0; i < count; i++) {
      const size = 1.0 + Math.random() * 1.5;
      const x = Math.random() * canvas.width;
      const y = Math.random() * canvas.height;
      const vx = (Math.random() - 0.5) * 0.35;
      const vy = (Math.random() - 0.5) * 0.35;
      const color = colors[Math.floor(Math.random() * colors.length)];
      particles.push(new Particle(x, y, vx, vy, size, color));
    }
  }
  
  function connect() {
    for (let a = 0; a < particles.length; a++) {
      for (let b = a + 1; b < particles.length; b++) {
        const dx = particles[a].x - particles[b].x;
        const dy = particles[a].y - particles[b].y;
        const dist = Math.sqrt(dx * dx + dy * dy);
        if (dist < 105) {
          let alpha = (1 - (dist / 105)) * 0.12;
          if (mouse.x !== null && mouse.y !== null) {
            const mdx1 = mouse.x - particles[a].x;
            const mdy1 = mouse.y - particles[a].y;
            const md1 = Math.sqrt(mdx1 * mdx1 + mdy1 * mdy1);
            if (md1 < mouse.radius) {
              alpha *= 2.0;
            }
          }
          ctx.strokeStyle = `rgba(255, 255, 255, ${Math.min(0.25, alpha).toFixed(2)})`;
          ctx.lineWidth = 0.5;
          ctx.beginPath();
          ctx.moveTo(particles[a].x, particles[a].y);
          ctx.lineTo(particles[b].x, particles[b].y);
          ctx.stroke();
        }
      }
    }
  }
  
  function animate() {
    ctx.clearRect(0, 0, canvas.width, canvas.height);
    particles.forEach(p => p.update());
    connect();
    requestAnimationFrame(animate);
  }
  
  window.addEventListener('resize', resize);
  resize();
  animate();
}

