async function loadState(){
  try {
    if (!activeSessionKey) return false;
    const encrypted = localStorage.getItem('state_enc');
    if (encrypted) {
      const decrypted = await decryptData(encrypted, activeSessionKey);
      if (decrypted) {
        S = JSON.parse(decrypted);
      } else {
        alert('Şifreli veriler çözülemedi. Lütfen tekrar giriş yapın.');
        handleLogout();
        return false;
      }
    }
    if(!S.settings)S.settings=defSettings();
    const def=defSettings();
    ['trendyol','hepsiburada','temu'].forEach(mp=>{
      if(!S.settings[mp])S.settings[mp]=def[mp];
      if(!S.settings[mp].desiTariff && def[mp].desiTariff)S.settings[mp].desiTariff=def[mp].desiTariff;
    });
    if(S.settings.trendyol){
      if(!S.settings.trendyol.desiTariffPTT)S.settings.trendyol.desiTariffPTT=def.trendyol.desiTariffPTT;
      if(!S.settings.trendyol.desiTariffTEX)S.settings.trendyol.desiTariffTEX=def.trendyol.desiTariffTEX;
      if(!S.settings.trendyol.defaultCargoFirm)S.settings.trendyol.defaultCargoFirm=def.trendyol.defaultCargoFirm;}
    if(S.settings.hepsiburada){
      if(!S.settings.hepsiburada.desiTariffPTT)S.settings.hepsiburada.desiTariffPTT=def.hepsiburada.desiTariffPTT;
      if(!S.settings.hepsiburada.desiTariffHJ)S.settings.hepsiburada.desiTariffHJ=def.hepsiburada.desiTariffHJ;
      if(!S.settings.hepsiburada.defaultCargoFirm)S.settings.hepsiburada.defaultCargoFirm=def.hepsiburada.defaultCargoFirm;}
    if(!S.products||S.products.length===0){
      S.products=defaultProducts.map(p=>({...p}));
      await saveState();
    }
    return true;
  } catch(e) {
    console.error('loadState hatası:', e);
    return false;
  }
}
async function saveState(){
  try {
    if (!activeSessionKey) return;
    const encrypted = await encryptData(JSON.stringify(S), activeSessionKey);
    localStorage.setItem('state_enc', encrypted);
  } catch(e) {
    console.error('saveState hatası:', e);
  }
}

