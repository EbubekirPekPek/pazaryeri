// EXCEL IMPORT
// ═══════════════════════════════════════════
let pending={mp:'',headers:[],rows:[]};
function onDrop(e,mp){e.preventDefault();document.getElementById(`ua-${mp}`).classList.remove('dv');const f=e.dataTransfer.files[0];if(f)processFile(f,mp)}
function onFileSelect(e,mp){const f=e.target.files[0];if(f)processFile(f,mp);e.target.value=''}
function processFile(file,mp){
  const r=new FileReader();
  r.onload=ev=>{try{
    let data;
    if(file.name.toLowerCase().endsWith('.csv')){
      const buf=new Uint8Array(ev.target.result);
      let txt;
      if(buf[0]===0xEF&&buf[1]===0xBB&&buf[2]===0xBF) txt=new TextDecoder('utf-8').decode(buf);
      else txt=new TextDecoder('windows-1254').decode(buf);
      if(txt.charCodeAt(0)===0xFEFF) txt=txt.slice(1);
      
      let sep=',';
      const lines=txt.split('\n');
      for(let l of lines){
        if(l.trim().length>0){if(l.includes(';'))sep=';';break;}
      }
      
      data=[];
      let curRow=[], curVal='', inQ=false;
      for(let i=0;i<txt.length;i++){
        let c=txt[i];
        if(inQ){
          if(c==='"'){if(txt[i+1]==='"'){curVal+='"';i++;}else inQ=false;}
          else curVal+=c;
        }else{
          if(c==='"')inQ=true;
          else if(c===sep){curRow.push(curVal);curVal='';}
          else if(c==='\n'||c==='\r'){
            if(c==='\r'&&txt[i+1]==='\n')i++;
            if(curRow.length>0||curVal)curRow.push(curVal);
            if(curRow.length>0)data.push(curRow);
            curRow=[];curVal='';
          }else curVal+=c;
        }
      }
      if(curRow.length>0||curVal){curRow.push(curVal);data.push(curRow);}
    } else {
      const wb=XLSX.read(new Uint8Array(ev.target.result),{type:'array',cellDates:false});
      data=XLSX.utils.sheet_to_json(wb.Sheets[wb.SheetNames[0]],{header:1,defval:''});
    }
    
    let hIdx=0;
    for(let i=0;i<Math.min(5,data.length);i++){if(data[i].filter(c=>String(c||'').trim()).length>=3){hIdx=i;break}}
    const headers=data[hIdx].map(h=>String(h||'').trim());
    const rows=data.slice(hIdx+1).filter(r=>r.some(c=>String(c||'').trim()));
    pending={mp,headers,rows};
    const autoMap=MP[mp].autoMap,mappings={};
    headers.forEach((h,idx)=>{const hl=h.toLowerCase().trim();Object.entries(autoMap).forEach(([field,variants])=>{if(mappings[field]!==undefined)return;if(variants.some(v=>hl===v||hl.includes(v)||v.includes(hl)))mappings[field]=idx})});
    document.getElementById('mapper-info').textContent=`${headers.length} sütun · ${rows.length} satır · ${MP[mp].icon} ${MP[mp].name}`;
    document.getElementById('mapper-fields').innerHTML=MP[mp].fields.map(f=>`<div class="mrow"><div class="mlabel">${f.label}${f.req?' <span style="color:var(--bad)">*</span>':''}</div><select id="mf-${f.key}" style="flex:1"><option value="">— Seçin —</option>${headers.map((h,i)=>`<option value="${i}" ${mappings[f.key]===i?'selected':''}>${h||'(Boş '+i+')'}</option>`).join('')}</select></div>`).join('');
    document.getElementById('modal-mapper').style.display='flex';
  }catch(err){alert('Dosya okunamadı: '+err.message)}};
  r.readAsArrayBuffer(file);
}
function confirmMapper(){
  const{mp,headers,rows}=pending;
  const cfg=MP[mp];const mappings={};
  cfg.fields.forEach(f=>{const el=document.getElementById(`mf-${f.key}`);if(el&&el.value!=='')mappings[f.key]=parseInt(el.value)});
  const missing=cfg.fields.filter(f=>f.req&&mappings[f.key]===undefined).map(f=>f.label);
  if(missing.length){alert('Zorunlu alanları seçin:\n'+missing.join(', '));return}
  const orders=rows.map((row,ri)=>{
    const o={_id:Date.now()+ri};
    cfg.fields.forEach(f=>{
      if(mappings[f.key]===undefined){o[f.key]='';return}
      let val=row[mappings[f.key]];
      if(['salePrice','commission','shippingCost','desi'].includes(f.key)){
        if(typeof val==='number'){o[f.key]=val;return}
        let s=String(val||'0').trim();
        let sign=s.includes('-')?-1:1;
        s=s.replace(/[^\d.,]/g,'');
        if(!s)o[f.key]=0;
        else{
          let lastC=s.lastIndexOf(','),lastD=s.lastIndexOf('.');
          let decI=Math.max(lastC,lastD);
          if(decI===-1)o[f.key]=parseFloat(s)*sign;
          else{
            let intP=s.substring(0,decI).replace(/[.,]/g,'');
            let decP=s.substring(decI+1).replace(/[.,]/g,'');
            o[f.key]=parseFloat(intP+'.'+decP)*sign;
          }
        }
      }
      else if(f.key==='quantity'){o[f.key]=parseInt(val||1)||1}
      else if(f.key==='date'){
        if(val!==''&&val!==null&&val!==undefined){
          if(typeof val==='number'){try{const dt=XLSX.SSF.parse_date_code(val);if(dt)val=`${dt.y}-${String(dt.m).padStart(2,'0')}-${String(dt.d).padStart(2,'0')}`}catch(e){val=String(val)}}
          else{const s=String(val).split(' ')[0].trim();const m=s.match(/^(\d{1,2})[.\/-](\d{1,2})[.\/-](\d{4})$/);if(m)val=`${m[3]}-${m[2].padStart(2,'0')}-${m[1].padStart(2,'0')}`;else val=s}
        }else val='';
        o[f.key]=val;
      }else{o[f.key]=String(val||'').trim()}
    });
    return o;
  }).filter(o=>o.productName||o.salePrice);
  if(!orders.length){alert('Aktarılabilecek satır bulunamadı.');return}
  const curr = S[mp].orders || [];
  if (curr.length > 0) {
    const act = prompt(`DİKKAT: Şu anda ${MP[mp].name} için yüklü ${curr.length} siparişiniz bulunuyor.\n\nEskileri SİLİP sadece bu dosyayı yüklemek için "1" yazın.\nEskilerin ÜSTÜNE EKLEMEK (ayları birleştirmek) için "2" yazın.\n\nİşlemi iptal etmek için "İptal"e basın.`, "2");
    if (act === "1") {
      S[mp].orders = orders;
    } else if (act === "2") {
      S[mp].orders = [...curr, ...orders];
    } else {
      return;
    }
  } else {
    S[mp].orders = orders;
  }
  saveState();closeModal('modal-mapper');
  populateMonthFilter();
  renderMP(mp);updateBadges();renderDashboard();
  showToast(`✅ ${fmtN(orders.length)} sipariş ${MP[mp].name}'a aktarıldı`);
}

