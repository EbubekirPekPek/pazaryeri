// AUTHENTICATION FLOW HANDLERS
// ═══════════════════════════════════════════
const GLOBAL_PASS_HASH = "3ead83f0549fd4f3748d5a3ddf561b1b69f6f53fda238afac56fa1295d23f0f4";

function showLoginScreen() {
  document.getElementById('login-overlay').style.display = 'flex';
  const screenLogin = document.getElementById('screen-login');
  if (screenLogin) screenLogin.style.display = 'block';
  const screenSet = document.getElementById('screen-set-pwd');
  if (screenSet) screenSet.style.display = 'none';
  setTimeout(() => {
    const inp = document.getElementById('login-password');
    if (inp) inp.focus();
  }, 100);
}

async function handleLogin() {
  const pwd = document.getElementById('login-password').value;
  const card = document.getElementById('login-card');
  if (!pwd) return;
  
  try {
    const hash = await sha256(pwd);
    if (hash === GLOBAL_PASS_HASH) {
      sessionStorage.setItem('session_key', pwd);
      
      let saltHex = localStorage.getItem('pwd_salt');
      if (!saltHex) {
        const salt = window.crypto.getRandomValues(new Uint8Array(16));
        saltHex = bufToHex(salt);
        localStorage.setItem('pwd_salt', saltHex);
        
        activeSessionKey = await deriveKey(pwd, salt);
        
        // Migration of legacy plain data if exists
        const legacyData = localStorage.getItem('pfp_v3');
        if (legacyData) {
          try {
            S = JSON.parse(legacyData);
            localStorage.removeItem('pfp_v3');
          } catch (e) {
            console.error('Legacy data migration failed:', e);
          }
        }
        await saveState();
      } else {
        activeSessionKey = await deriveKey(pwd, hexToBuf(saltHex));
      }
      
      const loaded = await loadState();
      if (loaded) {
        document.getElementById('login-overlay').style.display = 'none';
        renderDashboard();
        updateBadges();
        
        initSpotlight();
        initConstellation();
        initClickRipple();
      }
    } else {
      card.classList.add('shake');
      setTimeout(() => card.classList.remove('shake'), 400);
      document.getElementById('login-password').value = '';
    }
  } catch (err) {
    console.error(err);
    alert('Giriş yapılırken hata oluştu.');
  }
}

function handleLogout() {
  activeSessionKey = null;
  sessionStorage.removeItem('session_key');
  const pwdInp = document.getElementById('login-password');
  if (pwdInp) pwdInp.value = '';
  showLoginScreen();
}


