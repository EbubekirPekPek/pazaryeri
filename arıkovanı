function calcMPStats(mp){
  const orders=getFilteredOrders(mp);
  let rev=0,comm=0,kargo=0,stopaj=0,sh=0,tah=0,pc=0,kdv=0,profit=0;
  orders.forEach(o=>{
    const d=calcOrderDetails(o,mp);
    rev+=d.totalRev;comm+=d.commission;kargo+=d.kargo;stopaj+=d.stopaj;
    sh+=d.sabitHizmet;tah+=d.tahsilat;pc+=d.pcTotal;kdv+=d.kdv;profit+=d.netProfit;
  });
  return{rev,comm,kargo,stopaj,sh,tah,pc,kdv,profit,count:orders.length};
}

function calcGlobal(){
  const g={rev:0,comm:0,kargo:0,stopaj:0,sh:0,tah:0,pc:0,kdv:0,profit:0,count:0};
  ['trendyol','hepsiburada','temu'].forEach(mp=>{const s=calcMPStats(mp);Object.keys(g).forEach(k=>{g[k]+=(s[k]||0)})});
  g.expTotal=getFilteredExpenses().reduce((s,e)=>s+TRY(e.amount),0);
  g.netProfit=g.profit-g.expTotal;
  return g;
}

function allOrders(){
  const all=[];
  ['trendyol','hepsiburada','temu'].forEach(mp=>(S[mp]?.orders||[]).forEach((o,i)=>all.push({...o,_mp:mp,_idx:i})));
  return all.sort((a,b)=>new Date(b.date||0)-new Date(a.date||0));
}

