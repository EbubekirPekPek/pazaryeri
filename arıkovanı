    .tab-panel.active .sgrid > *:nth-child(2) { animation-delay: 0.08s; }
    .tab-panel.active .sgrid > *:nth-child(3) { animation-delay: 0.12s; }
    .tab-panel.active .sgrid > *:nth-child(4) { animation-delay: 0.16s; }
    .tab-panel.active .sgrid > *:nth-child(5) { animation-delay: 0.20s; }
