window.runCounters = function() {
  try {
    document.querySelectorAll('.sv').forEach(el => {
      if(el.classList.contains('counted')) return;
      const txt = el.textContent || '';
      if(txt.includes('₺')) {
        const val = parseFloat(txt.replace(/[^\d,-]/g,'').replace(',','.'));
        if(!isNaN(val)) {
          el.classList.add('counted');
          let start = null;
          const dur = 800;
          const step = ts => {
            if(!start) start = ts;
            let p = (ts - start) / dur;
            if (p > 1) p = 1;
            if (p < 0 || isNaN(p)) p = 1;
            el.textContent = '₺' + (p * val).toLocaleString('tr-TR', {minimumFractionDigits: 2, maximumFractionDigits: 2});
            if(p < 1) requestAnimationFrame(step);
            else el.textContent = txt;
          };
          requestAnimationFrame(step);
        }
      }
    });
  } catch (e) { console.error('runCounters error', e); }
};

window.sortTable = function(tableId, colIdx, type, thEl) {
  try {
    const table = document.getElementById(tableId); if(!table) return;
    const tbody = table.querySelector('tbody'); if(!tbody) return;
    const rows = Array.from(tbody.querySelectorAll('tr'));
    const isAsc = thEl.dataset.dir !== 'asc'; thEl.dataset.dir = isAsc ? 'asc' : 'desc';
    rows.sort((a,b)=>{
      const cA = a.children[colIdx], cB = b.children[colIdx];
      let v1 = cA ? cA.textContent.trim() : '', v2 = cB ? cB.textContent.trim() : '';
      if(type==='num'){v1=parseFloat(v1.replace(/[^\d,-]/g,'').replace(',','.'))||0;v2=parseFloat(v2.replace(/[^\d,-]/g,'').replace(',','.'))||0;}
      return isAsc ? (v1>v2?1:-1) : (v1<v2?1:-1);
    });
    rows.forEach(r=>tbody.appendChild(r));
  } catch (e) { console.error('sortTable error', e); }
};

window.runSim = function() {
  try {
    const mpEl = document.getElementById('sim-mp'), priceEl = document.getElementById('sim-price'), costEl = document.getElementById('sim-cost'), desiEl = document.getElementById('sim-desi'), commEl = document.getElementById('sim-comm');
    if (!mpEl || !priceEl || !costEl || !desiEl || !commEl) return;
    const mp = mpEl.value, price = parseFloat(priceEl.value)||0, cost = parseFloat(costEl.value)||0, desi = parseFloat(desiEl.value)||0, commRate = parseFloat(commEl.value)||0;
    const kargoObj = calcKargo(mp, price, desi);
    const kargo = kargoObj ? kargoObj.price : 0;
    const comm = price * (commRate / 100);
    let sh = 0; if(mp==='trendyol') sh = 4.49 * 1.20; else if(mp==='hepsiburada') sh = price * 0.02 * 1.20;
    const tah = ((price / 1.2) * 0.2) - ((cost / 1.2) * 0.2), stopaj = comm * 0.15;
    const net = price - (comm + sh + kargo + tah + stopaj + cost);
    const el = document.getElementById('sim-result'), marj = price>0 ? (net/price)*100 : 0;
    if(el) {
      el.innerHTML = `${fmt(net)} <span style="font-size:12px;opacity:0.8">(%${marj.toFixed(1)})</span>`;
      el.style.color = net>=0 ? 'var(--ok)' : 'var(--bad)';
    }
  } catch (e) { console.error('runSim error', e); }
};
