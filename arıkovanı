      filter: drop-shadow(0 0 12px rgba(129, 140, 248, 0.4));
    }
    .login-title {
      font-size: 20px;
      font-weight: 700;
      color: var(--text);
      margin-bottom: 8px;
      position: relative;
      z-index: 1;
      letter-spacing: -0.5px;
