      text-align: center;
      position: relative;
      overflow: hidden;
      animation: loginFadeIn 0.5s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }
    .login-card::before {
      content: '';
      position: absolute;
      top: -50%; left: -50%;
      width: 200%; height: 200%;
      background: radial-gradient(circle, rgba(129, 140, 248, 0.08) 0%, transparent 60%);
      pointer-events: none;
      z-index: 0;
    }
    @keyframes loginFadeIn {
      from { opacity: 0; transform: translateY(20px); }
      to { opacity: 1; transform: translateY(0); }
    }
    .login-logo {
      margin-bottom: 24px;
      position: relative;
      z-index: 1;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 60px; height: 60px;
