function addTariffRow(mp,tKey){const t=S.settings[mp][tKey]||[];const last=t[t.length-1]||{d:1,p:100};t.push({d:last.d+1,p:last.p+10});saveState();renderAyarlar();setTimeout(()=>document.querySelectorAll('.stab').forEach(t=>{if(t.textContent.includes('Kargo'))t.click()}),10)}
function saveTariffs(){
  ['desiTariffPTT','desiTariffTEX'].forEach(k=>{if(S.settings.trendyol?.[k])S.settings.trendyol[k].sort((a,b)=>a.d-b.d)});
  if(S.settings.hepsiburada?.desiTariff)S.settings.hepsiburada.desiTariff.sort((a,b)=>a.d-b.d);
  if(S.settings.temu?.desiTariff)S.settings.temu.desiTariff.sort((a,b)=>a.d-b.d);
  saveState();showToast('✅ Kargo tarifeleri kaydedildi');
}

