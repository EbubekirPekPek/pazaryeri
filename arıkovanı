
<!DOCTYPE html>
<html lang="tr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Pazaryeri Finans Paneli</title>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&display=swap');
    :root {
      --bg: #09090b; 
      --surface: rgba(20, 20, 25, 0.45); 
      --surface2: rgba(28, 28, 35, 0.65); 
      --border: rgba(255, 255, 255, 0.08);
      --border-light: rgba(255, 255, 255, 0.04);
      --text: #f8fafc; 
      --text2: #94a3b8; 
      --accent: #818cf8;
      --accent-hover: #6366f1;
      --accent-glow: rgba(129, 140, 248, 0.15);
      --ty: #f97316; 
      --hp: #c084fc; 
      --temu: #60a5fa;
      --ok: #34d399; 
      --bad: #f87171; 
      --warn: #fbbf24;
      --glass-blur: blur(24px);
      --shadow: 0 16px 40px rgba(0, 0, 0, 0.5);
      --card-radius: 16px;
      --transition-smooth: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }
    *{box-sizing:border-box;margin:0;padding:0}
    body {
      font-family: 'Outfit', system-ui, sans-serif;
      letter-spacing: -0.1px;
      background: var(--bg);
      background-image: 
        radial-gradient(circle at 15% 0%, rgba(99, 102, 241, 0.15) 0px, transparent 40%),
        radial-gradient(circle at 85% 100%, rgba(192, 132, 252, 0.12) 0px, transparent 40%),
        radial-gradient(circle at 50% 50%, rgba(249, 115, 22, 0.08) 0px, transparent 50%);
      background-size: 200% 200%;
      animation: ambientBG 20s ease-in-out infinite alternate;
      color: var(--text);
      min-height: 100vh;
      display: flex;
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
    }
    @keyframes ambientBG {
      0% { background-position: 0% 0%; }
      50% { background-position: 100% 100%; }
      100% { background-position: 0% 50%; }
    }

    /* SIDEBAR */
    .sidebar {
      width: 240px;
      min-height: 100vh;
      background: rgba(12, 12, 16, 0.65);
      backdrop-filter: var(--glass-blur);
      -webkit-backdrop-filter: var(--glass-blur);
      border-right: 1px solid var(--border);
      box-shadow: 10px 0 35px rgba(0,0,0,0.3);
      display: flex;
      flex-direction: column;
      position: fixed;
      top: 0;
      left: 0;
      z-index: 100;
      overflow-y: auto;
      transition: width 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }
    .logo {
      padding: 24px 20px 20px;
      border-bottom: 1px solid var(--border-light);
    }
    .logo-t {
      display: flex;
      align-items: center;
      gap: 12px;
    }
    .logo-text {
      font-size: 22px;
      font-weight: 800;
      background: linear-gradient(135deg, #818cf8, #c084fc, #f97316, #818cf8);
      background-size: 300% 300%;
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      letter-spacing: -0.5px;
      animation: gradientText 8s ease infinite;
    }
    @keyframes gradientText {
      0% { background-position: 0% 50%; }
      50% { background-position: 100% 50%; }
      100% { background-position: 0% 50%; }
    }
    .logo-svg { flex-shrink: 0; transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1); filter: drop-shadow(0 0 10px rgba(129,140,248,0.5)); }
    .logo:hover .logo-svg { transform: scale(1.15) rotate(-5deg); }
    .logo-s {
      font-size: 11px;
      color: var(--text2);
      margin-top: 4px;
      font-weight: 500;
      letter-spacing: 0.5px;
    }
    .nav-sec {
      padding: 20px 20px 8px;
      font-size: 11px;
      letter-spacing: 1.5px;
      text-transform: uppercase;
      color: var(--text2);
      font-weight: 600;
      opacity: 0.7;
    }
    .ni {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 12px 20px;
      cursor: pointer;
      color: var(--text2);
      font-size: 14px;
      font-weight: 500;
      border-left: 3px solid transparent;
      transition: var(--transition-smooth);
      user-select: none;
      position: relative;
    }
    .ni:hover {
      background: rgba(255, 255, 255, 0.04);
      color: var(--text);
      transform: translateX(4px);
    }
    .ni.active {
      color: var(--text);
      border-left-color: transparent;
      background: linear-gradient(90deg, rgba(129,140,248,0.15) 0%, transparent 100%);
    }
    .ni.active.ni-ty {
      background: linear-gradient(90deg, rgba(249,115,22,0.15) 0%, transparent 100%);
    }
    .ni.active.ni-hp {
      background: linear-gradient(90deg, rgba(192,132,252,0.15) 0%, transparent 100%);
    }
    .ni.active.ni-temu {
      background: linear-gradient(90deg, rgba(96,165,250,0.15) 0%, transparent 100%);
    }
    .ni.active::before {
      content: '';
      position: absolute;
      left: 0; top: 15%; height: 70%; width: 4px;
      background: var(--accent);
      border-radius: 0 4px 4px 0;
      box-shadow: 0 0 12px var(--accent);
      transition: background 0.3s, box-shadow 0.3s;
    }
    .ni.active.ni-ty::before {
      background: var(--ty);
      box-shadow: 0 0 12px var(--ty);
    }
    .ni.active.ni-hp::before {
      background: var(--hp);
      box-shadow: 0 0 12px var(--hp);
    }
    .ni.active.ni-temu::before {
      background: var(--temu);
      box-shadow: 0 0 12px var(--temu);
    }
    .nbadge {
      margin-left: auto;
      background: var(--accent);
      color: #fff;
      font-size: 11px;
      padding: 2px 8px;
      border-radius: 100px;
      font-weight: 600;
      box-shadow: 0 0 12px rgba(129, 140, 248, 0.6);
    }

    /* COLLAPSED SIDEBAR */
    body.sidebar-collapsed .sidebar { width: 72px; }
    body.sidebar-collapsed .logo { padding: 24px 0 20px; display: flex; justify-content: center; align-items: center; }
    body.sidebar-collapsed .logo-t { font-size: 24px; }
    body.sidebar-collapsed .logo-t span.logo-text, body.sidebar-collapsed .logo-s, body.sidebar-collapsed .nav-sec, body.sidebar-collapsed .ni-t { display: none; }
    body.sidebar-collapsed .nbadge { display: none !important; }
    body.sidebar-collapsed .ni { justify-content: center; padding: 16px 0; border-left: none; }
    body.sidebar-collapsed .ni:hover { transform: scale(1.1); }
    body.sidebar-collapsed .ni.active::before { width: 3px; height: 50%; top: 25%; left: 2px; border-radius: 10px; }
    body.sidebar-collapsed .logo-svg { width: 30px; height: 30px; margin: 0; }
    .ni-i { font-size: 16px; margin-right: 6px; transition: font-size 0.2s, margin 0.2s, width 0.2s, height 0.2s, transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1); display: inline-flex; align-items: center; justify-content: center; }
    .ni:hover .ni-i { transform: scale(1.2) rotate(3deg); }
    img.ni-i { width: 18px; height: 18px; object-fit: contain; border-radius: 4px; }
    body.sidebar-collapsed img.ni-i { width: 22px; height: 22px; margin: 0; }
    
    .mp-logo-img { height: 1.1em; width: 1.1em; object-fit: contain; vertical-align: text-bottom; margin-right: 4px; border-radius: 3px; display: inline-block; filter: drop-shadow(0 0 4px rgba(255,255,255,0.2)); }

    /* MAIN */
    .main { margin-left: 240px; flex: 1; min-width: 0; display: flex; flex-direction: column; transition: margin-left 0.3s cubic-bezier(0.4, 0, 0.2, 1); }
    body.sidebar-collapsed .main { margin-left: 72px; }
    .topbar {
      background: rgba(12, 12, 16, 0.65);
      backdrop-filter: var(--glass-blur);
      -webkit-backdrop-filter: var(--glass-blur);
      border-bottom: 1px solid var(--border-light);
      padding: 18px 32px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      position: sticky;
      top: 0;
      z-index: 50;
    }
    .topbar-t { font-size: 20px; font-weight: 600; letter-spacing: -0.5px; }
    .topbar-d { font-size: 13px; color: var(--text2); font-weight: 500; }
    .content { padding: 32px; flex: 1; }

    /* PANELS */
    .tab-panel { display: none; animation: fadeIn 0.3s ease; }
    .tab-panel.active { display: block; }
    @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }

    /* STATS & CARDS OVERLAYS */
    .sc, .cc, .tw, .ubox, .mphead {
      position: relative;
      overflow: hidden;
    }
    .sc::after, .cc::after, .tw::after, .ubox::after, .mphead::after {
      content: '';
      position: absolute;
      inset: 0;
      border-radius: inherit;
      background: radial-gradient(
        350px circle at var(--mouse-x, 0px) var(--mouse-y, 0px),
        rgba(255, 255, 255, 0.04),
        transparent 80%
      );
      opacity: 0;
      transition: opacity 0.5s ease;
      pointer-events: none;
      z-index: 1;
    }
    .sc::before, .cc::before, .tw::before, .ubox::before, .mphead::before {
      content: '';
      position: absolute;
      inset: 0;
      border-radius: inherit;
      padding: 1px;
      background: radial-gradient(
        250px circle at var(--mouse-x, 0px) var(--mouse-y, 0px),
        rgba(255, 255, 255, 0.12),
        transparent 60%
      );
      -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
      -webkit-mask-composite: xor;
      mask-composite: exclude;
      opacity: 0;
      transition: opacity 0.5s ease;
      pointer-events: none;
      z-index: 2;
    }
    .sc:hover::after, .cc:hover::after, .tw:hover::after, .ubox:hover::after, .mphead:hover::after,
    .sc:hover::before, .cc:hover::before, .tw:hover::before, .ubox:hover::before, .mphead:hover::before {
      opacity: 1;
    }

    /* Brand-specific spotlight borders */
    .sc.ty::before, .mphead.ty::before {
      background: radial-gradient(
        250px circle at var(--mouse-x, 0px) var(--mouse-y, 0px),
        rgba(249, 115, 22, 0.35),
        transparent 60%
      );
    }
    .sc.hp::before, .mphead.hp::before {
      background: radial-gradient(
        250px circle at var(--mouse-x, 0px) var(--mouse-y, 0px),
        rgba(192, 132, 252, 0.35),
        transparent 60%
      );
    }
    .sc.tm::before, .sc.temu::before, .mphead.temu::before {
      background: radial-gradient(
        250px circle at var(--mouse-x, 0px) var(--mouse-y, 0px),
        rgba(96, 165, 250, 0.35),
        transparent 60%
      );
    }

    .sgrid { display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 20px; margin-bottom: 28px; }
    .sc {
      background: var(--surface);
      backdrop-filter: var(--glass-blur);
      -webkit-backdrop-filter: var(--glass-blur);
      border: 1px solid var(--border);
      border-top: 1px solid rgba(255,255,255,0.15);
      border-bottom: 1px solid rgba(0,0,0,0.3);
      border-left-width: 4px;
      border-radius: var(--card-radius);
      padding: 22px 24px;
      box-shadow: var(--shadow), inset 0 1px 0 rgba(255,255,255,0.05);
      transition: var(--transition-smooth);
    }
    .sc:hover { transform: translateY(-4px) scale(1.02); box-shadow: 0 20px 40px rgba(0,0,0,0.65), inset 0 1px 0 rgba(255,255,255,0.15); }
    
    /* Marketplace Theme Colors & Glow effects on Hover */
    .sc.ac { border-left-color: var(--accent); }
    .sc.ac:hover { border-color: rgba(129, 140, 248, 0.4); box-shadow: 0 20px 40px rgba(129, 140, 248, 0.15), var(--shadow); }
    
    .sc.ok { border-left-color: var(--ok); }
    .sc.ok:hover { border-color: rgba(52, 211, 153, 0.4); box-shadow: 0 20px 40px rgba(52, 211, 153, 0.15), var(--shadow); }
    
    .sc.wa { border-left-color: var(--warn); }
    .sc.wa:hover { border-color: rgba(251, 191, 36, 0.4); box-shadow: 0 20px 40px rgba(251, 191, 36, 0.12), var(--shadow); }
    
    .sc.ba { border-left-color: var(--bad); }
    .sc.ba:hover { border-color: rgba(248, 113, 113, 0.4); box-shadow: 0 20px 40px rgba(248, 113, 113, 0.12), var(--shadow); }
    
    .sc.ty { border-left-color: var(--ty); }
    .sc.ty:hover { border-color: rgba(249, 115, 22, 0.4); box-shadow: 0 20px 40px rgba(249, 115, 22, 0.15), var(--shadow); }
    
    .sc.hp { border-left-color: var(--hp); }
    .sc.hp:hover { border-color: rgba(192, 132, 252, 0.4); box-shadow: 0 20px 40px rgba(192, 132, 252, 0.15), var(--shadow); }
    
    .sc.tm, .sc.temu { border-left-color: var(--temu); }
    .sc.tm:hover, .sc.temu:hover { border-color: rgba(96, 165, 250, 0.4); box-shadow: 0 20px 40px rgba(96, 165, 250, 0.15), var(--shadow); }
    
    .sl { font-size: 12px; color: var(--text2); text-transform: uppercase; letter-spacing: 1px; margin-bottom: 8px; font-weight: 600; position: relative; z-index: 2; }
    .sv { font-size: 26px; font-weight: 700; line-height: 1.1; letter-spacing: -0.5px; position: relative; z-index: 2; }
    .ss { font-size: 12.5px; color: var(--text2); margin-top: 8px; font-weight: 500; position: relative; z-index: 2; }

    /* CHARTS */
    .cgrid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 28px; }
    .cc {
      background: var(--surface);
      backdrop-filter: var(--glass-blur);
      -webkit-backdrop-filter: var(--glass-blur);
      border: 1px solid var(--border);
      border-top: 1px solid rgba(255,255,255,0.15);
      border-bottom: 1px solid rgba(0,0,0,0.3);
      border-radius: var(--card-radius);
      padding: 24px;
      box-shadow: var(--shadow), inset 0 1px 0 rgba(255,255,255,0.05);
      transition: var(--transition-smooth);
    }
    .cc:hover { transform: translateY(-4px); border-color: rgba(255,255,255,0.15); box-shadow: 0 20px 45px rgba(0,0,0,0.55); }
    .ct { font-size: 15px; font-weight: 600; margin-bottom: 18px; letter-spacing: -0.3px; position: relative; z-index: 2; }
    .ch { position: relative; height: 250px; z-index: 2; }

    /* TABLE */
    .tw {
      background: var(--surface);
      backdrop-filter: var(--glass-blur);
      -webkit-backdrop-filter: var(--glass-blur);
      border: 1px solid var(--border);
      border-top: 1px solid rgba(255,255,255,0.15);
      border-bottom: 1px solid rgba(0,0,0,0.3);
      border-radius: var(--card-radius);
      overflow: hidden;
      margin-bottom: 28px;
      box-shadow: var(--shadow), inset 0 1px 0 rgba(255,255,255,0.05);
      transition: var(--transition-smooth);
    }
    .th { padding: 18px 24px; display: flex; align-items: center; justify-content: space-between; border-bottom: 1px solid var(--border-light); gap: 12px; flex-wrap: wrap; background: rgba(0,0,0,0.2); }
    .tt { font-size: 16px; font-weight: 600; letter-spacing: -0.3px; }
    .ta { display: flex; gap: 10px; align-items: center; flex-wrap: wrap; }
    .ts { overflow: auto; max-height: calc(100vh - 230px); }
    table { width: 100%; border-collapse: separate; border-spacing: 0; min-width: 700px; }
    th { position: sticky; top: 0; z-index: 10; background: rgba(20, 20, 25, 0.9); padding: 14px 24px; text-align: left; font-size: 12px; text-transform: uppercase; letter-spacing: 1px; color: var(--text2); font-weight: 600; white-space: nowrap; border-bottom: 1px solid var(--border); backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px); box-shadow: 0 4px 10px rgba(0,0,0,0.15); }
    td { padding: 14px 24px; font-size: 13.5px; border-bottom: 1px solid var(--border-light); font-weight: 500; transition: background 0.2s; }
    tr { transition: transform 0.2s cubic-bezier(0.4, 0, 0.2, 1), box-shadow 0.2s; position: relative; }
    tr:last-child td { border-bottom: none; }
    tr:hover td { background: rgba(255,255,255,0.05); }
    tr:hover { transform: translateY(-1.5px) scale(1.002); box-shadow: 0 8px 24px rgba(0,0,0,0.3); z-index: 5; }
    tr:hover td:first-child { border-top-left-radius: 12px; border-bottom-left-radius: 12px; }
    tr:hover td:last-child { border-top-right-radius: 12px; border-bottom-right-radius: 12px; }
    tfoot td { position: sticky; bottom: 0; z-index: 10; background: rgba(20, 20, 25, 0.9); font-weight: 600; border-top: 1px solid var(--border); backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px); box-shadow: 0 -4px 10px rgba(0,0,0,0.15); }

    /* BADGE */
    .badge { display: inline-flex; align-items: center; justify-content: center; padding: 4px 10px; border-radius: 100px; font-size: 11.5px; font-weight: 600; letter-spacing: 0.3px; box-shadow: inset 0 1px 0 rgba(255,255,255,0.1); }
    .b-ok { background: rgba(52,211,153,0.15); color: var(--ok); }
    .b-wa { background: rgba(251,191,36,0.15); color: var(--warn); }
    .b-ba { background: rgba(248,113,113,0.15); color: var(--bad); }
    .b-ac { background: rgba(129,140,248,0.15); color: var(--accent); }
    .b-ty { background: rgba(249,115,22,0.15); color: var(--ty); }
    .b-hp { background: rgba(192, 132, 252, 0.15); color: var(--hp); }
    .b-tm { background: rgba(96, 165, 250, 0.15); color: var(--temu); }
    .b-br { background: rgba(52,211,153,0.1); color: var(--ok); border: 1px solid rgba(52,211,153,0.3); }
    .b-ds { background: rgba(129,140,248,0.1); color: var(--accent); border: 1px solid rgba(129,140,248,0.3); }

    /* BUTTONS */
    .btn { display: inline-flex; align-items: center; justify-content: center; gap: 6px; padding: 10px 18px; border-radius: 10px; border: none; cursor: pointer; font-size: 13.5px; font-weight: 600; transition: var(--transition-smooth); white-space: nowrap; font-family: inherit; position: relative; overflow: hidden; }
    .btn::after { content: ''; position: absolute; inset: 0; background: linear-gradient(180deg, rgba(255,255,255,0.15) 0%, transparent 100%); opacity: 0.5; pointer-events: none; }
    .bp { background: var(--accent); color: #fff; box-shadow: 0 4px 14px rgba(129,140,248,0.4), inset 0 1px 0 rgba(255,255,255,0.2); }
    .bp:hover { background: var(--accent-hover); transform: translateY(-2px); box-shadow: 0 8px 25px rgba(129,140,248,0.65), inset 0 1px 0 rgba(255,255,255,0.2); }
    .bs { background: rgba(255,255,255,0.05); color: var(--text); border: 1px solid rgba(255,255,255,0.1); backdrop-filter: blur(10px); box-shadow: inset 0 1px 0 rgba(255,255,255,0.05); }
    .bs:hover { background: rgba(255,255,255,0.1); transform: translateY(-2px); border-color: rgba(255,255,255,0.2); box-shadow: 0 8px 20px rgba(0,0,0,0.3); }
    .bd { background: rgba(248,113,113,0.1); color: var(--bad); border: 1px solid rgba(248,113,113,0.3); }
    .bd:hover { background: rgba(248,113,113,0.2); transform: translateY(-2px); }
    .bty { background: var(--ty); color: #fff; box-shadow: 0 4px 14px rgba(249,115,22,0.3); }
    .bty:hover { transform: translateY(-2px); box-shadow: 0 8px 20px rgba(249,115,22,0.45); }
    .bhp { background: var(--hp); color: #fff; box-shadow: 0 4px 14px rgba(192, 132, 252, 0.3); }
    .bhp:hover { transform: translateY(-2px); box-shadow: 0 8px 20px rgba(192, 132, 252, 0.45); }
    .btm { background: var(--temu); color: #fff; box-shadow: 0 4px 14px rgba(96, 165, 250, 0.3); }
    .btm:hover { transform: translateY(-2px); box-shadow: 0 8px 20px rgba(96, 165, 250, 0.45); }
    .btn.sm { padding: 6px 12px; font-size: 12px; border-radius: 8px; }

    /* UPLOAD */
    .ubox { background: var(--surface); border: 1px solid var(--border); border-radius: var(--card-radius); padding: 24px; margin-bottom: 24px; box-shadow: var(--shadow); backdrop-filter: var(--glass-blur); -webkit-backdrop-filter: var(--glass-blur); }
    .uarea { border: 2px dashed rgba(255,255,255,0.15); border-radius: 12px; padding: 32px; text-align: center; cursor: pointer; transition: var(--transition-smooth); background: rgba(0,0,0,0.2); }
    .uarea:hover, .uarea.dv { border-color: var(--accent); background: rgba(129,140,248,0.08); transform: scale(1.01); box-shadow: 0 0 20px rgba(129, 140, 248, 0.15); }
    .ui { font-size: 42px; margin-bottom: 12px; display: block; transition: transform 0.3s; }
    .uarea:hover .ui { transform: translateY(-4px); }
    .ut { font-size: 15px; font-weight: 600; margin-bottom: 6px; }
    .us { font-size: 13px; color: var(--text2); }

    /* FORMS */
    .fg { margin-bottom: 16px; }
    .fg label { display: block; font-size: 13px; font-weight: 500; color: var(--text2); margin-bottom: 8px; }
    input, select, textarea { width: 100%; background: rgba(0,0,0,0.2); border: 1px solid rgba(255,255,255,0.15); border-radius: 10px; padding: 10px 14px; color: var(--text); font-size: 14px; outline: none; font-family: inherit; font-weight: 500; transition: border-color 0.2s, box-shadow 0.2s; }
    input:focus, select:focus, textarea:focus { border-color: var(--accent); box-shadow: 0 0 0 3px rgba(129,140,248,0.15); }
    select option, select optgroup { background: #18181b; color: var(--text); }
    .fgrid { display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 16px; }
    input[type=checkbox] { width: 18px; height: 18px; cursor: pointer; border-radius: 4px; accent-color: var(--accent); }

    /* MODAL */
    .mbk { position: fixed; inset: 0; background: rgba(0,0,0,0.85); backdrop-filter: blur(10px); -webkit-backdrop-filter: blur(10px); z-index: 2000; display: flex; align-items: center; justify-content: center; padding: 20px; animation: fadeIn 0.25s cubic-bezier(0.16, 1, 0.3, 1); }
