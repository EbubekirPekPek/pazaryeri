    const d=calcOrderDetails(o,o._mp);
    prodMap[compKey].rev+=d.totalRev;
    prodMap[compKey].qty+=(parseInt(o.quantity||1)||1);
    prodMap[compKey].profit+=d.netProfit;
    prodMap[compKey].lastPrice=d.salePrice;
    
    if(o.date) {
      let dStr = String(o.date).split(' ')[0].trim();
      const parts = dStr.split(/[.\/-]/);
