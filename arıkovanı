function filterMaliyetlerTable(q) {
  q = q.toLowerCase();
  document.querySelectorAll('.mal-row').forEach(row => {
    const name = row.querySelector('.mal-name').textContent.toLowerCase();
    row.style.display = name.includes(q) ? '' : 'none';
  });
}
function openProductModal(idx){
  const p = idx!==undefined ? S.products[idx] : {};
  document.getElementById('pr-n').value = p.name || '';
  document.getElementById('pr-c').value = p.cost || '';
  document.getElementById('pr-d').value = p.desi || '';
  document.getElementById('pr-ps').value = p.packSize || '';
  document.getElementById('pr-k').value = p.kdvRate !== undefined ? p.kdvRate : 20;
  document.getElementById('pr-idx').value = idx !== undefined ? idx : '';
  
  // Sipariş listesinden checkboxları oluştur
  let aliases = [];
  if (Array.isArray(p.aliases)) aliases = p.aliases;
  else if (typeof p.aliases === 'string') aliases = p.aliases.split(',').map(x=>x.trim()).filter(x=>x);
  
  const uniqueNames = [...new Set(allOrders().map(o=>o.productName).filter(x=>x))].sort();
  aliases.forEach(a => { if(!uniqueNames.includes(a)) uniqueNames.push(a); });
  
  const listHTML = uniqueNames.map(name => {
    const checked = aliases.includes(name) ? 'checked' : '';
    return `<label class="alias-lbl" style="display:flex;align-items:flex-start;gap:6px;font-size:11px;cursor:pointer;padding:6px;border-radius:4px;background:var(--bg);border:1px solid transparent">
      <input type="checkbox" value="${esc(name)}" ${checked} style="margin-top:2px" />
      <span style="word-break:break-word">${esc(name)}</span>
    </label>`;
  }).join('');
  
  document.getElementById('pr-alias-list').innerHTML = listHTML || '<div style="font-size:11px;color:var(--text2);padding:4px">Önce Excel yükleyin...</div>';
  document.getElementById('pr-alias-search').value = '';
  
  document.getElementById('modal-prod').style.display='flex';
}
function filterAliasList(q){
  q = q.toLowerCase();
  document.querySelectorAll('.alias-lbl').forEach(lbl => {
    const text = lbl.textContent.toLowerCase();
    lbl.style.display = text.includes(q) ? 'flex' : 'none';
  });
}
function saveProduct(){
  const n=document.getElementById('pr-n').value.trim(),c=parseFloat(document.getElementById('pr-c').value);
  if(!n||isNaN(c)){alert('Ad ve maliyet girin');return}
  const d=parseFloat(document.getElementById('pr-d').value)||undefined;
  const ps=parseInt(document.getElementById('pr-ps').value)||undefined;
  
  const checkedAliases = [];
  document.querySelectorAll('#pr-alias-list input[type="checkbox"]:checked').forEach(cb => {
    checkedAliases.push(cb.value);
  });
  
  const k=parseInt(document.getElementById('pr-k').value);
  const obj={name:n,cost:c,...(d?{desi:d}:{}),...(ps?{packSize:ps}:{}),aliases:checkedAliases,kdvRate:k};
  const idx=document.getElementById('pr-idx').value;
  if(idx!=='')S.products[parseInt(idx)]=obj;else S.products.push(obj);
  saveState();closeModal('modal-prod');renderMaliyetler();
}
function deleteProduct(i){if(!confirm('Bu kaydı silmek istiyor musunuz?'))return;S.products.splice(i,1);saveState();renderMaliyetler()}
window.resetProductsToDefault = function(){
  S.products=defaultProducts.map(p=>({...p}));
  saveState();
  renderMaliyetler();
  showToast('Varsayılan ürün listesi başarıyla yüklendi!');
}

