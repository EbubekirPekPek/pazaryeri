function openExpenseModal(){document.getElementById('ex-n').value='';document.getElementById('ex-a').value='';document.getElementById('ex-d').value=todayStr();document.getElementById('ex-nt').value='';document.getElementById('modal-exp').style.display='flex'}
function saveExpense(){const n=document.getElementById('ex-n').value.trim(),a=parseFloat(document.getElementById('ex-a').value);if(!n||isNaN(a)||a<=0){alert('Ad ve geçerli tutar girin');return}S.expenses.push({name:n,amount:a,category:document.getElementById('ex-c').value,date:document.getElementById('ex-d').value,marketplace:document.getElementById('ex-m').value,note:document.getElementById('ex-nt').value.trim()});saveState();closeModal('modal-exp');renderGiderler();updateBadges()}
