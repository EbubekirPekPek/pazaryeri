function getFilteredOrders(mp = null) {
  let orders = mp ? (S[mp]?.orders||[]).map((o,i)=>({...o,_mp:mp,_idx:i})) : allOrders();
  if (currentGlobalDateFilter === 'all') return orders;
  
  const now = new Date();
  const filterVal = currentGlobalDateFilter;
  
  return orders.filter(o => {
    if (!o.date) return false;
    let dt = new Date(o.date);
    if(isNaN(dt) && typeof o.date==='string'){
       const parts=o.date.split('.');
       if(parts.length===3) dt=new Date(`${parts[2]}-${parts[1]}-${parts[0]}`);
    }
    if (isNaN(dt)) return false;
    
    if (filterVal === '7d') {
      return (now - dt) <= 7 * 24 * 60 * 60 * 1000;
    } else if (filterVal === '30d') {
      return (now - dt) <= 30 * 24 * 60 * 60 * 1000;
    } else if (filterVal === 'thisMonth') {
      return dt.getMonth() === now.getMonth() && dt.getFullYear() === now.getFullYear();
    } else if (filterVal === 'lastMonth') {
      let lm = now.getMonth() - 1;
      let y = now.getFullYear();
      if(lm < 0){ lm = 11; y--; }
      return dt.getMonth() === lm && dt.getFullYear() === y;
    } else {
      const mStr = `${dt.getFullYear()}-${String(dt.getMonth() + 1).padStart(2, '0')}`;
      return filterVal === mStr;
    }
  });
}

